{
    "Name": "httpx",
    "Homepage": "https://github.com/projectdiscovery/httpx",
    "Mirror": "https://github.com/gmmirror/httpx",
    "Description": "httpx is a fast and multi-purpose HTTP toolkit that allows running multiple probes using the retryablehttp library.",
    "Dependency": [
        "git",
        "golang"
    ],
    "Install": [
        "git clone --depth 1 https://github.com/gmmirror/httpx $PREFIX/tmp/gmmirror_httpx",
        "chmod +x -R $PREFIX/tmp/gmmirror_httpx",
        "bash $PREFIX/tmp/gmmirror_httpx/install.sh",
        "rm -rf $PREFIX/tmp/gmmirror_httpx"
    ],
    "Uninstall": [
        "rm -rf $PREFIX/opt/httpx",
        "rm -f $PREFIX/bin/httpx"
    ]
}