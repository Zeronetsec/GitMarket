{
    "Name": "ffuf",
    "Homepage": "https://github.com/ffuf/ffuf",
    "Mirror": "https://github.com/gmmirror/ffuf",
    "Description": "Fast web fuzzer written in Go",
    "Dependency": [
        "git",
        "golang"
    ],
    "Install": [
        "git clone --depth 1 https://gmmirror/ffuf $PREFIX/tmp/gmmirror_ffuf",
        "chmod +x -R $PREFIX/tmp/gmmirror_ffuf",
        "bash $PREFIX/tmp/gmmirror_ffuf/install.sh",
        "rm -rf $PREFIX/tmp/gmmirror_ffuf"
    ],
    "Uninstall": [
        "rm -rf $PREFIX/opt/ffuf",
        "rm -f $PREFIX/bin/ffuf"
    ]
}