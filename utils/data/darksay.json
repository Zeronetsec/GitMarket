{
    "Name": "darksay",
    "Homepage": "https://github.com/Blziko/darksay",
    "Mirror": "https://github.com/gmmirror/darksay",
    "Description": "random dark quotes",
    "Dependency": [
        "git",
        "ruby"
    ],
    "Install": [
        "git clone --depth 1 https://github.com/gmmirror/darksay $PREFIX/tmp/gmmirror_darksay",
        "chmod +x -R $PREFIX/tmp/gmmirror_darksay",
        "bash $PREFIX/tmp/gmmirror_darksay/install.sh",
        "rm -rf $PREFIX/tmp/gmmirror_darksay"
    ],
    "Uninstall": [
        "rm -rf $PREFIX/opt/darksay",
        "rm -f $PREFIX/bin/darksay"
    ]
}