{
    "Name": "sqlmap",
    "Homepage": "https://github.com/sqlmapproject/sqlmap",
    "Mirror": "https://github.com/gmmirror/sqlmap",
    "Description": "Automatic SQL injection and database takeover tool",
    "Dependency": [
        "git",
        "python3"
    ],
    "Install": [
        "git clone --depth 1 https://github.com/gmmirror/sqlmap $PREFIX/tmp/gmmirror_sqlmap",
        "chmod +x -R $PREFIX/tmp/gmmirror_sqlmap",
        "bash $PREFIX/tmp/gmmirror_sqlmap/install.sh",
        "rm -rf $PREFIX/tmp/gmmirror_sqlmap"
    ],
    "Uninstall": [
        "rm -rf $PREFIX/opt/sqlmap",
        "rm -f $PREFIX/bin/sqlmap"
    ]
}