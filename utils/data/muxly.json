{
    "Name": "muxly",
    "Homepage": "https://github.com/Zeronetsec/Muxly",
    "Mirror": "https://github.com/gmmirror/muxly",
    "Description": "Muxly is a Swiss Army knife for Termux customization, including fonts, themes, cursor styles, shortcuts, and rootfs management.",
    "Dependency": [
        "git"
    ],
    "Install": [
        "git clone --depth 1 https://github.com/gmmirror/muxly $PREFIX/tmp/gmmirror_muxly",
        "chmod +x -R $PREFIX/tmp/gmmirror_muxly",
        "bash $PREFIX/tmp/gmmirror_muxly/install.sh",
        "rm -rf $PREFIX/tmp/gmmirror_muxly"
    ],
    "Uninstall": [
        "rm -rf $PREFIX/opt/muxly",
        "rm -f $PREFIX/bin/muxly"
    ]
}