{
    "Name": "chprompt",
    "Homepage": "https://github.com/Zeronetsec/Chprompt",
    "Mirror": "https://github.com/gmmirror/chprompt",
    "Description": "Chprompt is a lightweight tool for switching Linux prompts instantly with 100+ built-in styles and zero dependencies.",
    "Dependency": [
        "git"
    ],
    "Install": [
        "git clone --depth 1 https://github.com/gmmirror/chprompt $PREFIX/tmp/gmmirror_chprompt",
        "chmod +x -R $PREFIX/tmp/gmmirror_chprompt",
        "bash $PREFIX/tmp/gmmirror_chprompt/install.sh",
        "rm -rf $PREFIX/tmp/gmmirror_chprompt"
    ],
    "Uninstall": [
        "rm -rf $PREFIX/opt/chprompt",
        "cat $HOME/.bashrc | grep -v 'chprompt' > $PREFIX/tmp/bashrc_tmp",
        "cat $PREFIX/tmp/bashrc_tmp > $HOME/.bashrc"
    ]
}