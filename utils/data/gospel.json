{
    "Name": "gospel",
    "Homepage": "https://github.com/Zeronetsec/Gospel",
    "Mirror": "https://github.com/gmmirror/gospel",
    "Description": "Gospel is a CLI toolkit for system exploration, security auditing, and data inspection.",
    "Dependency": [
        "git"
    ],
    "Install": [
        "git clone --depth 1 https://github.com/gmmirror/gospel $PREFIX/tmp/gmmirror_gospel",
        "chmod +x -R $PREFIX/tmp/gmmirror_gospel",
        "bash $PREFIX/tmp/gmmirror_gospel/install.sh",
        "rm -rf $PREFIX/tmp/gmmirror_gospel"
    ],
    "Uninstall": [
        "rm -rf $PREFIX/opt/gospel",
        "rm -f $PREFIX/bin/gospel"
    ]
}