{
    "Name": "apktool",
    "Homepage": "https://github.com/iBotPeaches/Apktool",
    "Mirror": "https://github.com/gmmirror/apktool",
    "Description": "A tool for reverse engineering Android apk files",
    "Dependency": [
        "git",
        "aapt",
        "openjdk-17",
        "wget"
    ],
    "Install": [
        "git clone --depth 1 https://github.com/gmmirror/apktool $PREFIX/opt/gmmirror_apktool",
        "chmod +x -R $PREFIX/opt/gmmirror_apktool",
        "bash $PREFIX/opt/gmmirror_apktool/install.sh",
        "rm -rf $PREFIX/opt/gmmirror_apktool"
    ],
    "Uninstall": [
        "rm -rf $PREFIX/opt/apktool",
        "rm -rf $PREFIX/bin/apktool"
    ]
}