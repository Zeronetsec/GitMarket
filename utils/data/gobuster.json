{
    "Name": "gobuster",
    "Homepage": "https://github.com/Oj/gobuster",
    "Mirror": "https://github.com/gmmirror/gobuster",
    "Description": "Directory/File, DNS and VHost busting tool written in Go",
    "Dependency": [
        "git",
        "golang"
    ],
    "Install": [
        "git clone --depth 1 https://github.com/gmmirror/gobuster $PREFIX/tmp/gmmirror_gobuster",
        "chmod +x -R $PREFIX/tmp/gmmirror_gobuster",
        "bash $PREFIX/tmp/gmmirror_gobuster/install.sh",
        "rm -rf $PREFIX/tmp/gmmirror_gobuster"
    ],
    "Uninstall": [
        "rm -rf $PREFIX/opt/gobuster",
        "rm -f $PREFIX/bin/gobuster"
    ]
}