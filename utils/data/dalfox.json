{
    "Name": "dalfox",
    "Homepage": "https://github.com/hahwul/dalfox",
    "Mirror": "https://github.com/gmmirror/dalfox",
    "Description": "Dalfox is a powerful open-source XSS scanner and utility focused on automation.",
    "Dependency": [
        "git",
        "golang"
    ],
    "Install": [
        "git clone --depth 1 https://github.com/gmmirror/dalfox $PREFIX/tmp/gmmirror_dalfox",
        "chmod +x -R $PREFIX/tmp/gmmirror_dalfox",
        "bash $PREFIX/tmp/gmmirror_dalfox/install.sh",
        "rm -rf $PREFIX/tmp/gmmirror_dalfox"
    ],
    "Uninstall": [
        "rm -rf $PREFIX/opt/dalfox",
        "rm -f $PREFIX/bin/dalfox"
    ]
}